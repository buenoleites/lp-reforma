# Token de acesso da Meta Conversions API.
# Copie este arquivo como .env.local e preencha o valor:
#   cp .env.example .env.local
#
# O arquivo .env.local nunca vai para o Git (já está no .gitignore).
#
# Onde encontrar o token:
#   Gerenciador de Eventos Meta -> Configurações -> API de Conversões
#   -> Gerar token de acesso
#
# Atenção: como este é um site estático, o token ficará visível no bundle JS
# do cliente. Para eventos com dados de usuário (leads), prefira chamar a CAPI
# de um backend (ex.: n8n).

VITE_META_ACCESS_TOKEN=cole_seu_token_aqui
